#!/usr/bin/env bash
# Build (if needed) and run the marten-writebook server.
#
# Sets CRYSTAL_LIBRARY_PATH because asdf 0.18 (Go-based) bypasses the
# upstream asdf-crystal bash wrapper that normally exports it, so the
# linker can't find libgc otherwise.
set -euo pipefail

cd "$(dirname "$0")/.."

export CRYSTAL_LIBRARY_PATH="${CRYSTAL_LIBRARY_PATH:+$CRYSTAL_LIBRARY_PATH:}$HOME/.asdf/installs/crystal/1.20.1/embedded/lib"

mkdir -p bin

needs_build=false
if [[ ! -x bin/server ]]; then
  needs_build=true
else
  if [[ -n "$(find config src shard.lock -type f \( -name '*.cr' -o -name 'shard.lock' \) -newer bin/server -print -quit 2>/dev/null)" ]]; then
    needs_build=true
  fi
fi

if $needs_build; then
  echo "==> Building bin/server..."
  crystal build src/server.cr -o bin/server
fi

echo "==> Starting server (Ctrl-C to stop)..."
exec ./bin/server "$@"
