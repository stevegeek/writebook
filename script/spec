#!/usr/bin/env bash
# Run the in-process (handler / model / lib) spec suite.
#
# Browser-driving system specs live under spec/system/ and are run separately
# via `script/spec_system` — they need a server subprocess + headless Chrome
# and are 10x slower to boot. Defaulting to the in-process tier keeps the
# dev loop fast.
#
# Usage: script/spec                         # all in-process specs
#        script/spec spec/foo_spec.cr        # one file (any path)
set -euo pipefail

cd "$(dirname "$0")/.."

export CRYSTAL_LIBRARY_PATH="${CRYSTAL_LIBRARY_PATH:+$CRYSTAL_LIBRARY_PATH:}$HOME/.asdf/installs/crystal/1.20.1/embedded/lib"

if [[ $# -eq 0 ]]; then
  # Pick up everything except spec/system/.
  files=$(find spec -name '*_spec.cr' -not -path 'spec/system/*' | sort)
  exec crystal spec $files
else
  exec crystal spec "$@"
fi
